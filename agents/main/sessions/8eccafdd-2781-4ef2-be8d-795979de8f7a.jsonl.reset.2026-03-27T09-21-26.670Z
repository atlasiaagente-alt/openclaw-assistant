{"type":"message","id":"6b32b291","parentId":"8ca023ef","timestamp":"2026-03-26T15:00:39.570Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"toolu_01YRjRhLLABdxP3JVsPk4RkE","name":"write","arguments":{"file_path":"C:\\Users\\Gustavo\\.openclaw\\workspace\\scripts\\fix_prometeo_table.py","content":"import json, os, urllib.request, urllib.error\n\nTOKEN = os.environ['NOTION_TOKEN']\nVERSION = '2025-09-03'\nHEADERS = {\n    'Authorization': 'Bearer ' + TOKEN,\n    'Notion-Version': VERSION,\n    'Content-Type': 'application/json',\n}\n\n\ndef notion(method, url, payload=None):\n    data = None if payload is None else json.dumps(payload).encode('utf-8')\n    req = urllib.request.Request(url, data=data, method=method, headers=HEADERS)\n    with urllib.request.urlopen(req) as resp:\n        body = resp.read().decode('utf-8')\n        return json.loads(body) if body else {}\n\n\ndef safe(label, fn):\n    try:\n        result = fn()\n        print('ok', label)\n        return result\n    except urllib.error.HTTPError as e:\n        body = ''\n        try:\n            body = e.read().decode('utf-8')\n        except Exception:\n            pass\n        print('error', label, e.code, body[:250])\n    except Exception as e:\n        print('error', label, repr(e))\n\n\ndef rich_text(content):\n    return [{\"type\": \"text\", \"text\": {\"content\": content}}]\n\n\ndef text_cell(content):\n    return [{\"type\": \"text\", \"text\": {\"content\": content}}]\n\n\ndef replace_row(row_id, cells):\n    return notion('PATCH', f'https://api.notion.com/v1/blocks/{row_id}', {\n        'table_row': {'cells': [text_cell(c) for c in cells]}\n    })\n\n\ndef get_children(block_id):\n    return notion('GET', f'https://api.notion.com/v1/blocks/{block_id}/children?page_size=100')\n\n\n# Fetch Prometeo table rows (id from dump: 3290a0b1-97cc-809a-b9aa-e84d03b4c898)\nprint('--- Fetching Prometeo table rows ---')\nprom_tbl = get_children('3290a0b1-97cc-809a-b9aa-e84d03b4c898')\nprom_rows = [(b['id'], b['type']) for b in prom_tbl.get('results', [])]\nfor i, (rid, rtype) in enumerate(prom_rows):\n    print(f'  row{i}: {rid} ({rtype})')\n\n# Fetch inbox table rows (id: 3290a0b1-97cc-80c8-a64f-d3d8e477793c)\nprint('--- Fetching Inbox table rows ---')\ninbox_tbl = get_children('3290a0b1-97cc-80c8-a64f-d3d8e477793c')\ninbox_rows = [(b['id'], b['type']) for b in inbox_tbl.get('results', [])]\nfor i, (rid, rtype) in enumerate(inbox_rows):\n    print(f'  row{i}: {rid} ({rtype})')\n\n# Clean Prometeo table: 7 cols (Tarea | Estado | Tipo | Prioridad | Impacto | Area | Notas)\n# row0 = header (skip), then data rows\nprom_data = [\n    ('Validar pagos Paddle',       'Waiting',     'Payment',  'Alta',  'Alto',  'Payments',  'Unificar con \"Validar Paddle webhook\" o definir si es tarea separada.'),\n    ('Comprar dominio',            'Definir',      'Infra',    'Alta',  'Alto',  'Infra',     'Decidir dominio final y ejecutar compra.'),\n    ('Ajustar UI dashboard',       'Definir',      'Feature',  'Media', 'Medio', 'Frontend',  'Concretar alcance minimo del ajuste visual.'),\n    ('Validar Paddle webhook',     'En progreso',  'TradeLab', 'Alta',  'Alto',  'Payments',  'Prioridad 1. Revisar handler/ruta, firma/secreto y actualizacion del estado de pago.'),\n]\nfor i, cells in enumerate(prom_data):\n    if i + 1 < len(prom_rows):\n        rid = prom_rows[i + 1][0]\n        safe(f'prom_row{i+1}', lambda r=rid, c=cells: replace_row(r, list(c)))\n\n# Clean inbox table: 7 cols (Tarea | Estado | Tipo | Prioridad | Impacto | Area | Notas)\n# row0 = header (skip), rest are blank or empty rows — just clear them\nfor i in range(1, len(inbox_rows)):\n    rid = inbox_rows[i][0]\n    safe(f'inbox_clear_row{i}', lambda r=rid: replace_row(r, ['', '', '', '', '', '', '']))\n\nprint('Prometeo + Inbox fix completo.')\n"}}],"api":"anthropic-messages","provider":"anthropic","model":"claude-sonnet-4-6","usage":{"input":3,"output":1350,"cacheRead":0,"cacheWrite":64535,"totalTokens":65888,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774537216393,"responseId":"msg_017fCBZgajJARC2hcMWbhP8M"}}
