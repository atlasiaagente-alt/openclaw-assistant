\": 1775135939107,\n      \"schedule\": {\n        \"kind\": \"cron\",\n        \"expr\": \"0 8 * * *\",\n        \"tz\": \"America/Bogota\"\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"Review the Gmail inbox of atlas.ia.agente@gmail.com using gog with a strict lightweight pass. Only capture: (1) pending items for today, (2) deadlines in the next 3 days, (3) forwarded items from Gustavo that need action today. Limit yourself to the most relevant items only. If a calendar action is obvious, propose or organize it briefly toward toledo970501@gmail.com; do not over-process. Then send Gustavo a concise WhatsApp reminder to +573183718246 with max 5 bullets and one clear next action if needed.\",\n        \"timeoutSeconds\": 420\n      },\n      \"delivery\": {\n        \"mode\": \"announce\",\n        \"channel\": \"whatsapp\",\n        \"to\": \"+573183718246\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1775221200000,\n        \"lastRunAtMs\": 1775135700020,\n        \"lastRunStatus\": \"ok\",\n        \"lastStatus\": \"ok\",\n        \"lastDurationMs\": 239087,\n        \"lastDeliveryStatus\": \"not-delivered\",\n        \"consecutiveErrors\": 0,\n        \"lastDelivered\": false\n      }\n    },\n    {\n      \"id\": \"8157ed89-ee52-482d-a791-31181c4fff11\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:main\",\n      \"name\": \"evening-email-review-and-calendar-check\",\n      \"enabled\": true,\n      \"createdAtMs\": 1774390767598,\n      \"updatedAtMs\": 1775088420057,\n      \"schedule\": {\n        \"kind\": \"cron\",\n        \"expr\": \"0 19 * * *\",\n        \"tz\": \"America/Bogota\"\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"Review the Gmail inbox of atlas.ia.agente@gmail.com with a strict evenin