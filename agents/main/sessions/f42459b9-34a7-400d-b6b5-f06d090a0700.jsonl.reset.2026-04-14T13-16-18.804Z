plication/json' }\n$body = @{ filter = @{ property='Status'; status=@{ does_not_equal='Done' } }; page_size = 100 } | ConvertTo-Json -Depth 10\n$r = Invoke-RestMethod -Method Post -Uri 'https://api.notion.com/v1/databases/32f0a0b1-97cc-81a8-9443-df3f85f2ffc7/query' -Headers $headers -Body $body\n$r.results | ForEach-Object {\n  $p=$_.properties\n  [PSCustomObject]@{\n    Task=($p.'Task name'.title.plain_text -join '')\n    Status=if($p.Status.status){$p.Status.status.name}else{''}\n    Priority=if($p.Priority.select){$p.Priority.select.name}else{''}\n    Area=($p.Area.rich_text.plain_text -join '')\n    Owner=($p.Owner.rich_text.plain_text -join '')\n    NextCheck=if($p.'Next check'.date){$p.'Next check'.date.start}else{''}\n    NextStep=($p.'Next step'.rich_text.plain_text -join '')\n    Due=if($p.Deadline.date){$p.Deadline.date.start}else{''}\n  }\n} | Sort-Object Priority,Status | Format-Table -AutoSize | Out-String -Width 260","workdir":"C:\\Users\\Gustavo\\.openclaw\\workspace-ares","yieldMs":10000,"timeout":30},"partialJson":"{\"command\":\"$headers = @{ 'Authorization' = \\\"Bearer $env:NOTION_TOKEN\\\"; 'Notion-Version' = '2022-06-28'; 'Content-Type' = 'application/json' }\\n$body = @{ filter = @{ property='Status'; status=@{ does_not_equal='Done' } }; page_size = 100 } | ConvertTo-Json -Depth 10\\n$r = Invoke-RestMethod -Method Post -Uri 'https://api.notion.com/v1/databases/32f0a0b1-97cc-81a8-9443-df3f85f2ffc7/query' -Headers $headers -Body $body\\n$r.results | ForEach-Object {\\n  $p=$_.properties\\n  [PSCustomObject]@{\\n    Task=($p.'Task name'.title.plain_text -join '')\\n    Status=if($p.Status.status){$p.Status.status.name}else{''}\\n    Priority=if($p.Priority.select){$p.Priority.select.name}else{''}\\n    Area=($p.Area.rich_text.plain_text -join '')\\n    Owner=($p.Owner.rich_text.plain_text -join '')\\n    NextCheck=if($p.'Next check'.date){$p.'Next check'.date.start}else{''}\\n    NextStep=($p.'Next step'.rich_text.plain_text -join '')\\n    Due=i