                   \"id\":  \"ares\",\r\n                                    \"name\":  \"ares\",\r\n                                    \"workspace\":  \"C:\\\\Users\\\\Gustavo\\\\.openclaw\\\\workspace-ares\",\r\n                                    \"agentDir\":  \"C:\\\\Users\\\\Gustavo\\\\.openclaw\\\\agents\\\\ares\\\\agent\",\r\n                                    \"groupChat\":  {\r\n                                                      \"mentionPatterns\":  [\r\n                                                                              \"\\\\bares\\\\b\",\r\n                                                                              \"\\\\bAres\\\\b\"\r\n                                                                          ],\r\n                                                      \"historyLimit\":  50\r\n                                                  },\r\n                                    \"model\":  {\r\n                                                  \"primary\":  \"ollama/qwen3:30b\",\r\n                                                  \"fallbacks\":  [\r\n                                                                    \"anthropic/claude-sonnet-4-6\",\r\n                                                                    \"openai-codex/gpt-5.4\"\r\n                                                                ]\r\n                                              }\r\n                                },\r\n                                {\r\n                                    \"id\":  \"prometeo\",\r\n                                    \"name\":  \"prometeo\",\r\n                                    \"workspace\":  \"C:\\\\Users\\\\Gustavo\\\\.openclaw\\\\workspace-prometeo\",\r\n                                    \"agentDir\":  \"C:\\\\Users\\\\Gustavo\\\\.openclaw\\\\agents\\\\prometeo\\\\agent\",\r\n                                    \"model\":  {\r\n                                                  \"primary\":  \"anthropic/claude-sonnet-4-6\",\r\n                                                  \"fallbacks\":  [\r\n                                                                    \"openai-codex/gpt-5.4\",\r\n                                                                    \"ollama/qwen3:30b\"\r\n                                                                ]\r\n                                              },\r\n                                    \"runtime\":  {\r\n                                                    \"type\":  \"acp\",\r\n                                                    \"acp\":  {\r\n                                                                \"agent\":  \"claude\",\r\n                                                                \"backend\":  \"acpx\",\r\n                                                                \"mode\":  \"persistent\",\r\n                                                                \"cwd\":  \"C:\\\\Users\\\\Gustavo\\\\Documents\\\\tradelab-front\"\r\n                                                            }\r\n                                                },\r\n                                    \"groupChat\":  {\r\n                                                      \"mentionPatterns\":  [\r\n                                                                              \"\\\\bprometeo\\\\b\",\r\n                                                                              \"\\\\bPrometeo\\\\b\"\r\n                                                                          ],\r\n                                                      \"historyLimit\":  50\r\n                                                  }\r\n                                }\r\n                            ]\r\n               },\r\n    \"tools\":  {\r\n                  \"profile\":  \"coding\",\r\n                  \"web\":  {\r\n                              \"search\":  {\r\n                                             \"enabled\":  true,\r\n                                             \"provider\":  \"duckduckgo\"\r\n                                         }\r\n                          },\r\n                  \"media\":  {\r\n                                \"audio\":  {\r\n                                              \"enabled\":  true,\r\n                                              \"attachments\":  {\r\n                                                                  \"mode\":  \"all\",\r\n                                                                  \"maxAttachments\":  4\r\n                                                              },\r\n                                              \"models\":  [\r\n                                                             {\r\n                                                                 \"type\":  \"cli\",\r\n                                                                 \"command\":  \"python\",\r\n                                                                 \"args\":  [\r\n                                                                              \"C:\\\\Users\\\\Gustavo\\\\.openclaw\\\\workspace\\\\scripts\\\\whisper-bridge.py\",\r\n                                                                              \"{{MediaPath}}\",\r\n                                                                              \"--model\",\r\n                                                                              \"base\",\r\n                                                                              \"--language\",\r\n                                                                              \"es\"\r\n                                                                          ],\r\n                                                                 \"timeoutSeconds\":  180\r\n                                                             }\r\n                                                         ],\r\n                                              \"echoTranscript\":  true,\r\n                                              \"echoFormat\":  \"ðŸ“ {transcript}\"\r\n                                          }\r\n                            },\r\n                  \"sessions\":  {\r\n                                   \"visibility\":  \"all\"\r\n                               },\r\n                  \"agentToAgent\":  {\r\n                                       \"enabled\":  true,\r\n                                       \"allow\":  [\r\n                                                     \"ares\",\r\n                                                     \"prometeo\",\r\n                                                     \"hestia\",\r\n                                                     \"main\"\r\n                                                 ]\r\n                                   },\r\n                  \"elevated\":  {\r\n                                   \"enabled\":  true,\r\n                                   \"allowFrom\":  {\r\n                                                     \"whatsapp\":  [\r\n                                                                      \"+573183718246\"\r\n                                                                  ]\r\n                                                 }\r\n                               },\r\n                  \"exec\":  {\r\n                               \"host\":  \"gateway\",\r\n                               \"security\":  \"full\",\r\n                               \"ask\":  \"off\"\r\n                           }\r\n              },\r\n    \"bindings\":  [\r\n                     {\r\n                         \"agentId\":  \"hestia\",\r\n                         \"match\":  {\r\n                                       \"channel\":  \"whatsapp\",\r\n                                       \"peer\":  {\r\n                                                    \"kind\":  \"direct\",\r\n                                                    \"id\":  \"+573144752380\"\r\n                                                }\r\n                                   }\r\n                     },\r\n                     {\r\n                         \"agentId\":  \"ares\",\r\n                         \"match\":  {\r\n                                       \"channel\":  \"whatsapp\",\r\n                                       \"peer\":  {\r\n                                                    \"kind\":  \"group\",\r\n                                                    \"id\":  \"120363424964463765@g.us\"\r\n                                                }\r\n                                   }\r\n                     },\r\n                     {\r\n                         \"agentId\":  \"prometeo\",\r\n                         \"match\":  {\r\n                                       \"channel\":  \"whatsapp\",\r\n                                       \"peer\":  {\r\n                                                    \"kind\":  \"group\",\r\n                                                    \"id\":  \"120363407571517396@g.us\"\r\n                                                }\r\n                                   }\r\n                     }\r\n                 ],\r\n    \"commands\":  {\r\n                     \"native\":  \"auto\",\r\n                     \"nativeSkills\":  \"auto\",\r\n                     \"restart\":  true,\r\n                     \"ownerDisplay\":  \"raw\"\r\n                 },\r\n    \"session\":  {\r\n                    \"dmScope\":  \"per-channel-peer\"\r\n                },\r\n    \"hooks\":  {\r\n                  \"internal\":  {\r\n                                   \"enabled\":  true,\r\n                                   \"entries\":  {\r\n                                                   \"session-memory\":  {\r\n                                                                          \"enabled\":  true\r\n                                                                    