ipt to summarize each task's title, status, owner, and notes. This should help in organizing everything neatly for easier reference. Let’s get this done!\"}]}"},{"type":"toolCall","id":"call_nlkWVvznglmSaB0dpW3RGsq8|fc_012e12a4adaf4cd90169c8093d624c81918a8e884e4762f68c","name":"exec","arguments":{"command":"$ErrorActionPreference='Stop'\n$headers = @{ 'Authorization' = \"Bearer $env:NOTION_TOKEN\"; 'Notion-Version' = '2025-09-03'; 'Content-Type' = 'application/json' }\n$body = '{\"page_size\":100}'\n$r = Invoke-RestMethod -Method Post -Uri 'https://api.notion.com/v1/data_sources/32f0a0b1-97cc-8185-b332-000b7592f8b3/query' -Headers $headers -Body $body\n$items = $r.results | ForEach-Object {\n  [pscustomobject]@{\n    id = $_.id\n    task = ($_.properties.'Task name'.title | ForEach-Object { $_.plain_text }) -join ''\n    owner = ($_.properties.Owner.rich_text | ForEach-Object { $_.plain_text }) -join ''\n    status = $_.properties.Status.status.name\n    priority = if ($_.properties.Priority.select) { $_.properties.Priority.select.name } else { '' }\n    area = ($_.properties.Area.rich_text | ForEach-Object { $_.plain_text }) -join ''\n    source = ($_.properties.Source.rich_text | ForEach-Object { $_.plain_text }) -join ''\n    notes = ($_.properties.Notes.rich_text | ForEach-Object { $_.plain_text }) -join ''\n  }\n}\n$items | Sort-Object task | ConvertTo-Json -Depth 5","workdir":"C:\\Users\\Gustavo\\.openclaw\\workspace","yieldMs":10000,"timeout":60},"partialJson":"{\"command\":\"$ErrorActionPreference='Stop'\\n$headers = @{ 'Authorization' = \\\"Bearer $env:NOTION_TOKEN\\\"; 'Notion-Version' = '2025-09-03'; 'Content-Type' = 'application/json' }\\n$body = '{\\\"page_size\\\":100}'\\n$r = Invoke-RestMethod -Method Post -Uri 'https://api.notion.com/v1/data_sources/32f0a0b1-97cc-8185-b332-000b7592f8b3/query' -Headers $headers -Body $body\\n$items = $r.results | ForEach-Object {\\n  [pscustomobject]@{\\n    id = $_.id\\n    task = ($_.properties.'Task name'.title | F